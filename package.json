{
    "name": "@olegpolyakov/tasks",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "workspaces": [
        "api",
        "app",
        "core",
        "db"
    ],
    "exports": {
        "./core": "./core/src/index.ts",
        "./db": "./db/src/index.ts"
    },
    "scripts": {
        "start": "npm start --workspace=api",
        "prestart": "npm run build --workspace=app",
        "link": "npm link && npm link @olegpolyakov/tasks",
        "update": "git submodule update --init --remote --merge --recursive"
    }
}